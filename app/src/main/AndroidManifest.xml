<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Requested on demand when a site asks (GeckoView PermissionDelegate). Must be declared here
         or the runtime request fails immediately. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <!-- Required for ReopenTabActivity to front a tab task when Deck taps its card. Without this,
         AppTask.moveToFront()/ActivityManager.moveTaskToFront() throws SecurityException. -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <permission
        android:name="com.hermes.browser.permission.READ_HISTORY"
        android:protectionLevel="signature" />

    <application
        android:name=".BrowserApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Browser"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".BrowserTabActivity"
            android:autoRemoveFromRecents="false"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|uiMode"
            android:documentLaunchMode="always"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
        </activity>

        <!-- Invisible trampoline Deck starts to front a specific tab task (see ReopenTabActivity). -->
        <activity
            android:name=".ReopenTabActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:launchMode="singleInstance"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Lets Deck enumerate live tab tasks (replies with each tab's task id + url). -->
        <receiver
            android:name=".EnumerateTabsReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.hermes.browser.ACTION_ENUMERATE_TABS" />
            </intent-filter>
        </receiver>

        <!-- Lets Deck close a specific tab (card swiped away in Deck) so it also leaves system recents. -->
        <receiver
            android:name=".CloseTabReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.hermes.browser.ACTION_CLOSE_TAB" />
            </intent-filter>
        </receiver>

        <provider
            android:name=".HistoryProvider"
            android:authorities="com.hermes.browser.history"
            android:exported="true"
            android:readPermission="com.hermes.browser.permission.READ_HISTORY" />

    </application>

</manifest>
